<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Login is the starting point -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="org.mountaineers.traillog.ui.auth.LoginFragment"
        android:label="Login" />

    <fragment
        android:id="@+id/mapFragment"
        android:name="org.mountaineers.traillog.ui.map.MapFragment"
        android:label="@string/title_map" />

    <fragment
        android:id="@+id/reportsFragment"
        android:name="org.mountaineers.traillog.ui.reports.ReportsFragment"
        android:label="@string/title_reports" />

    <fragment
        android:id="@+id/statsFragment"
        android:name="org.mountaineers.traillog.ui.stats.StatsFragment"
        android:label="@string/title_stats" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="org.mountaineers.traillog.ui.export.SettingsFragment"
        android:label="Settings" />

    <!-- Action: Login → Map and clear back stack (so user can't go back to login) -->
    <action
        android:id="@+id/action_login_to_map"
        app:destination="@id/mapFragment"
        app:popUpTo="@id/loginFragment"
        app:popUpToInclusive="true" />

</navigation>