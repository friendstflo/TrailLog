<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/fab_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="12dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="4dp">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_cache_area"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/cd_cache_area"
            android:src="@drawable/ic_download_map"
            app:backgroundTint="?attr/colorTertiary"
            app:elevation="6dp"
            app:fabSize="mini"
            app:tint="@android:color/white" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_trail_preset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/cd_trail_preset"
            android:src="@android:drawable/ic_dialog_map"
            app:backgroundTint="?attr/colorSecondary"
            app:elevation="6dp"
            app:fabSize="mini"
            app:tint="@android:color/white" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_pin_here"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/cd_pin_here"
            android:src="@drawable/ic_add_pin"
            app:backgroundTint="?attr/colorPrimary"
            app:elevation="6dp"
            app:fabSize="mini"
            app:tint="@android:color/white" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_my_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/cd_my_location"
            android:src="@drawable/ic_my_location"
            app:backgroundTint="?attr/colorPrimary"
            app:elevation="6dp"
            app:fabSize="normal"
            app:tint="@android:color/white" />

    </LinearLayout>

</FrameLayout>
