<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Crew Name -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_crew_name"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_crew_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/settings_crew_name_hint"
        android:inputType="textPersonName|textCapWords"
        android:autofillHints="name"
        android:importantForAutofill="yes"
        android:textSize="18sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_default_landowner"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <Spinner
        android:id="@+id/spinner_landowner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <!-- Optional basemap (OpenStreetMap / USGS Topo); tiles cache offline via OSMdroid -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_map_basemap"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_map_basemap_hint"
        android:textSize="13sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginTop="4dp" />

    <Spinner
        android:id="@+id/spinner_map_basemap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btn_save_crew"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_save_crew"
        android:layout_marginTop="8dp" />

    <!-- Export CSV -->
    <Button
        android:id="@+id/btn_export_csv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/export_csv_landowner"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tv_last_sync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_last_sync_never"
        android:textSize="14sp"
        android:padding="16dp"
        android:textColor="@android:color/darker_gray" />

    <Button
        android:id="@+id/btn_force_sync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_force_sync"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1B5E20"
        android:layout_marginTop="16dp"
        android:padding="12dp" />
</LinearLayout>
